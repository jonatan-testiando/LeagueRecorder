{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LeagueRecorder",
  "version": "0.2.0",
  "identifier": "com.alejandro.tauri-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LeagueRecorder",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$VIDEOS/LeagueRecorder/*", "$VIDEOS/LeagueRecorder/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "bin/ffmpeg.exe": "bin/ffmpeg.exe",
      "python-runtime": "python-runtime",
      "../python_scripts/analyzer.py": "python_scripts/analyzer.py",
      "../assets/cursors": "assets/cursors"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jonatan-testiando/LeagueRecorder/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzNjc0NDhGMDE3QzcyNEQKUldSTmNud0JqMFJuOHhuNHRMQ3poY0ZMek5IanpJdi83T2h1SldGaDB4U2VFUjFqZFB1bDhOSE4K"
    }
  }
}
